# Kopieer dit bestand naar .env en vul de waarden in
# Op Render.com: voeg deze toe onder Environment Variables

# Jouw OpenAI API key (te vinden op platform.openai.com)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# De URL van jouw frontend (voor CORS beveiliging)
# Voorbeeld: https://ttdigitaldesign.nl
FRONTEND_URL=https://ttdigitaldesign.nl

# Poort (Render zet dit automatisch)
PORT=3000
