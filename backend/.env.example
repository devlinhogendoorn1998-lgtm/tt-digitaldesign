# Kopieer dit bestand naar .env en vul de waarden in
# Op Render.com: voeg deze toe onder Environment Variables

# Jouw Google Gemini API key (te vinden op aistudio.google.com)
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# De URL van jouw frontend (voor CORS beveiliging)
# Voorbeeld: https://tt-digitaldesign.onrender.com
FRONTEND_URL=https://tt-digitaldesign.onrender.com

# Poort (Render zet dit automatisch)
PORT=3000
